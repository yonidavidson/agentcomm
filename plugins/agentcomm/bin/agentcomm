#!/bin/sh
# agentcomm launcher: plugin hosts can add this bin/ directory to PATH, so
# agents can run bare `agentcomm ...` as the skill documents. Resolves
# the prebuilt CLI relative to this script (survives version-dir upgrades).
self="$0"
while [ -h "$self" ]; do
  link="$(readlink "$self")"
  case "$link" in
    /*) self="$link" ;;
    *) self="$(dirname "$self")/$link" ;;
  esac
done
dir="$(cd "$(dirname "$self")" && pwd)"
exec node "$dir/../dist/cli.js" "$@"
