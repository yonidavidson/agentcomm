#!/bin/sh
# agentcomm launcher: add this bin/ directory to PATH (npm's global install
# does it for you) so agents can run bare `agentcomm ...`. Resolves the
# built CLI relative to this script.
self="$0"
while [ -h "$self" ]; do
  link="$(readlink "$self")"
  case "$link" in
    /*) self="$link" ;;
    *) self="$(dirname "$self")/$link" ;;
  esac
done
dir="$(cd "$(dirname "$self")" && pwd)"
exec node "$dir/../dist/cli.js" "$@"
